FROM ubuntu:24.04

# 基本パッケージ
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    curl \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

# llama.cppのビルド
WORKDIR /opt
RUN git clone https://github.com/ggerganov/llama.cpp.git
WORKDIR /opt/llama.cpp
RUN cmake -B build -DLLAMA_NATIVE=OFF && \
    cmake --build build --config Release -j$(nproc)

# modelsディレクトリをマウントポイントとして用意
RUN mkdir -p /models

WORKDIR /opt/llama.cpp
